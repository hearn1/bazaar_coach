# GitHub OAuth App configuration for local development.
# Copy this file to .env in the repo root and fill in your values.
# .env is gitignored — do NOT commit real secrets.
#
# See docs/GITHUB_OAUTH_APP.md for full setup instructions.

# Set to "true" only when testing OAuth-backed flows locally.
# Bazaar Coach does not implement OAuth today; keep this false unless you are
# actively developing that feature.
BAZAAR_COACH_GITHUB_OAUTH_ENABLED=false

# Public Client ID from your GitHub OAuth App.
# Safe to share in source; not a secret.
BAZAAR_COACH_GITHUB_OAUTH_CLIENT_ID=

# Callback URL registered in your GitHub OAuth App.
# Only needed for loopback-redirect flow; leave blank for Device Flow.
BAZAAR_COACH_GITHUB_OAUTH_CALLBACK_URL=http://127.0.0.1:5555/oauth/github/callback

# Target repository for issue reporting and update checks.
# Defaults to hearn1/bazaar_coach if not set.
BAZAAR_COACH_GITHUB_REPO=hearn1/bazaar_coach

# CLIENT_SECRET is intentionally omitted from this template.
# If your OAuth flow requires a client secret, set it in your shell session
# only — never commit it or bundle it into a packaged build.
# Prefer Device Flow (no secret needed) for desktop apps.
